                <Font size="16.0" />
            </font>
        </Label>
        <Button fx:id="supprimer" layoutX="318.0" layoutY="295.0" mnemonicParsing="false" onAction="#SupprimerPatient" text="Supprimer " />
        <TextField fx:id="txtId" layoutX="237.0" layoutY="217.0" />
        <Label layoutX="130.0" layoutY="217.0" prefHeight="25.0" prefWidth="52.0" text="ID :">
            <font>
                <Font size="16.0" />
            </font>
        </Label>
      <Label layoutX="80.0" layoutY="69.0" prefHeight="25.0" prefWidth="313.0" text="Suppression d'un Patient " textFill="#102ef4">
         <font>
            <Font name="System Bold Italic" size="24.0" />
         </font>
      </Label>
    </children>

</AnchorPane>
